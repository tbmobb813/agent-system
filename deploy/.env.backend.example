# =============================================================================
# Backend environment — copy to backend/.env on the VPS
# Never commit the real .env to git.
# =============================================================================

# Environment
ENVIRONMENT=production
DEBUG=False

# Database (generated by setup.sh)
DATABASE_URL=postgresql://agent_user:YOUR_DB_PASS@localhost/agent_db

# OpenRouter (your existing key)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Budget
OPENROUTER_BUDGET_MONTHLY=30.0

# Security — generate a strong key: openssl rand -hex 32
# This is the key the frontend uses to authenticate with the backend.
BACKEND_API_KEY=sk-agent-YOUR-STRONG-KEY-HERE

# CORS — update once SSL is live
CORS_ORIGINS=["https://agent.techtrendwire.com"]
SITE_URL=https://agent.techtrendwire.com

# SearXNG (already running on your VPS)
SEARXNG_URL=http://localhost:8888

# Optional — Brave Search fallback
BRAVE_SEARCH_API_KEY=

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Execution limits
MAX_STREAM_SECONDS=300
