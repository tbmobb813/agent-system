# =============================================================================
# Frontend environment — copy to frontend/.env.local on the VPS
# Never commit the real .env.local to git.
# =============================================================================

# Direct backend URL for SSE streaming (goes through Nginx, not Next.js proxy)
# Nginx routes /api/backend/agent/stream → FastAPI with proxy_buffering off
NEXT_PUBLIC_BACKEND_URL=https://agent.techtrendwire.com/api/backend

# Must match BACKEND_API_KEY in backend/.env
NEXT_PUBLIC_BACKEND_API_KEY=sk-agent-YOUR-STRONG-KEY-HERE
