OPENROUTER_API_KEY= # Get from openrouter.ai
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=ANON KEY

# Backend master keys (comma-separated). First key is a convenient default for local UI.
BACKEND_API_KEY=sk-agent-local-dev,sk-agent-telegram-bot

# If true, API keys (except master keys) always require PostgreSQL validation — even in development.
# REQUIRE_DATABASE_API_KEY=false

# Optional: restrict browser_automation to these host suffixes (comma-separated), after SSRF checks.
# Example: wikipedia.org,.github.io
# BROWSER_AUTOMATION_ALLOWED_HOST_SUFFIXES=

# Docker Compose — Next.js server proxies /api/backend to the API (not the browser).
BACKEND_URL=http://backend:8000

# Optional: browser calls this URL directly instead of /api/backend (requires CORS on the API).
# NEXT_PUBLIC_API_URL=
